# WebDAVViewer 发布签名配置
# ====================================
# 复制此文件为 keystore.properties 并填入真实的签名信息
# 注意：keystore.properties 文件不应提交到版本控制系统

# 密钥库文件路径（相对于项目根目录）
storeFile=release.keystore

# 密钥库密码
storePassword=your_store_password

# 密钥别名
keyAlias=webdavviewer

# 密钥密码
keyPassword=your_key_password

# ====================================
# 创建签名密钥的方法
# ====================================
# 在命令行执行以下命令创建签名密钥：
#
# keytool -genkey -v -keystore release.keystore \
#   -alias webdavviewer \
#   -keyalg RSA \
#   -keysize 2048 \
#   -validity 10000 \
#   -storepass your_store_password \
#   -keypass your_key_password
#
# 然后填写相关信息：
# - 您的名字与姓氏: 您的名字
# - 您的组织单位: 组织单位
# - 您的组织: 组织名称
# - 您的城市或地区: 城市
# - 您的省/市/自治区: 省份
# - 国家/地区代码: CN
#
# 创建后将 release.keystore 文件放在项目根目录
